{
  "name": "tetrachess-server",
  "version": "1.0.0",
  "description": "Real-time multiplayer chess server",
  "main": "server.ts",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node --loader ts-node/esm server.ts",
    "dev": "tsx server.ts",
    "build": "echo 'TypeScript server ready'"
